# Terraform working files
.terraform/
.terraform.tfstate.lock.info

# State (may contain the github_token secret) — never commit
*.tfstate
*.tfstate.*

# Backend config carrying the R2 endpoint (account-specific) — not committed
r2.backend.hcl

# Variable files with secrets; keep the example
*.tfvars
!*.tfvars.example

crash.log
crash.*.log
